# Cloudflare Zero Trust Tunnel connector token
# Create in Cloudflare Dashboard:
# Zero Trust -> Networks -> Tunnels -> Create Tunnel -> Docker
CLOUDFLARE_TUNNEL_TOKEN=replace_with_your_tunnel_token

# Optional TURN settings for runtime-issued coturn credentials.
# These are served by /api/ice-servers and should not be exposed in the frontend.
# TURN_URLS can be a comma-separated list, for example:
# TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
# TURN_SHARED_SECRET=replace_with_a_long_random_secret
# TURN_TTL_SECONDS=86400

# WebRTC ICE configuration baked into the Vite client build.
# This remains a fallback if /api/ice-servers is unavailable.
VITE_PEER_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302","stun:stun1.l.google.com:19302"]}]

# Optional: if you later self-host PeerJS signaling instead of using the public
# default PeerJS server, set these before rebuilding the image.
# This repo can serve PeerJS signaling from the same app process at /peerjs.
# Leave host empty to use the current origin.
# VITE_PEER_HOST=
# VITE_PEER_PORT=443
# VITE_PEER_PATH=/peerjs
# VITE_PEER_SECURE=true
