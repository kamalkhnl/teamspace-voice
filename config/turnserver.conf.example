listening-port=3478
tls-listening-port=5349

# Replace with the VM's private LAN IP.
listening-ip=192.168.10.12

# Replace with the public IP or public DNS that clients reach directly.
external-ip=PUBLIC_IP

realm=voice.local
server-name=teamspace-voice-turn

fingerprint
use-auth-secret
static-auth-secret=XzJpqqUoffJ59dJZDK2x+XVffgB3OYdteGNVvoj6x1ceBkWfb14xpEFlCCtIw+IO

no-multicast-peers
no-cli

# Certificates are required for turns: on 5349.
# cert=/etc/letsencrypt/live/turn.example.com/fullchain.pem
# pkey=/etc/letsencrypt/live/turn.example.com/privkey.pem

# Relay ports must also be forwarded from the company edge firewall/NAT to this VM.
min-port=49160
max-port=49200

log-file=/var/log/turnserver/turnserver.log
simple-log
